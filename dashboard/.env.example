# Hermes — env vars
#
# All optional for Phase 0 skeleton. With ZERO env vars set, the route
# runs against simulator adapters (see dashboard/src/lib/hermes/README.md).
#
# Provision real values in Vercel project settings → Environment Variables
# before flipping to live mode. Never commit real values.

# --- GHL ---
# Webhook signing secret from GHL → Settings → Webhooks
GHL_WEBHOOK_SECRET=
# API key with scopes: read contacts, send SMS (Phase 1)
GHL_API_KEY=
# Outbound number / location ID — Phase 1 only
GHL_OUTBOUND_NUMBER_ID=

# --- LLM (intent classification) ---
# When set, intent classifier uses Anthropic instead of regex heuristic
ANTHROPIC_API_KEY=

# --- Slack ---
# Bot User OAuth Token (xoxb-...). Scopes: chat:write, reactions:read
SLACK_BOT_TOKEN=
# Channel IDs (not names) — e.g. C0XXXXXXXXX
SLACK_HERMES_CHANNEL=
SLACK_BOTLOG_CHANNEL=
# Signing secret for verifying inbound Slack events (Phase 1 reaction handler)
SLACK_SIGNING_SECRET=

# --- Google Drive (retrievers: contracts, CO log, drawings index) ---
# Stringified service-account JSON
DRIVE_SERVICE_ACCOUNT_JSON=

# --- Smartsheet (retriever: schedule) ---
SMARTSHEET_API_TOKEN=
